# adgen-backend environment — copy this file to .env and fill in the values.
# Do NOT put real secrets here (this file is committed). Real values go in .env,
# which is git-ignored. See adgen-platform/mdfiles/14-SECRETS-I-NEED-FROM-YOU.md.

# --- ElevenLabs (audio TTS — the only paid audio API) ---
ELEVENLABS_API_KEY=          # 🔴 NEEDS YOU — elevenlabs.io -> profile -> API Keys
ELEVENLABS_VOICE_ID=         # 🔴 NEEDS YOU — elevenlabs.io -> Voices -> Hindi-capable voice -> Voice ID

# --- ComfyUI on RunPod (video generation; pod transport for now) ---
COMFY_POD_URLS=              # 🔴 NEEDS YOU — comma-separated https://<pod-id>-8188.proxy.runpod.net
